PORT=5000
DATABASE_URL=postgresql://user:password@host:26257/houseiq?sslmode=verify-full

# Auth0 API validation (required by the backend)
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_AUDIENCE="https://api.houseiq.app"

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL="gpt-4o-mini"

AWS_REGION="us-east-2"
AWS_S3_BUCKET_NAME="your-private-houseiq-document-bucket"

# Local development only.
# Use an IAM role when the application is deployed inside AWS.
AWS_ACCESS_KEY_ID="your-local-access-key-id"
AWS_SECRET_ACCESS_KEY="your-local-secret-access-key"

# ---------------------------------------------------------
# Ownership security tests (npm test)
# ---------------------------------------------------------
# Use an Auth0 application with the Resource Owner Password
# grant enabled, authorized for AUTH0_AUDIENCE.
# Create two distinct database users for cross-user checks.
#
AUTH0_TEST_CLIENT_ID="your-auth0-test-client-id"
AUTH0_TEST_CLIENT_SECRET="your-auth0-test-client-secret"
AUTH0_TEST_USER_A_USERNAME="user-a@example.com"
AUTH0_TEST_USER_A_PASSWORD="user-a-password"
AUTH0_TEST_USER_B_USERNAME="user-b@example.com"
AUTH0_TEST_USER_B_PASSWORD="user-b-password"
