{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "name": "HouseIQ API",
    "description": "Full HouseIQ backend collection.\n\n## Setup\n1. Import `HouseIQ.Local.postman_environment.json` and select **HouseIQ Local**.\n2. Paste an Auth0 API access token into `accessToken` (audience must match the backend `AUTH0_AUDIENCE`).\n3. Run **Auth → Get current user** to confirm the token works.\n4. Run **Homes → List homes** or **Create home** — scripts auto-save `homeId`.\n\n## Auth notes\n- Protected routes: `GET /api/auth/me`, `POST /api/homes`, `GET /api/homes`.\n- Other home-scoped routes are currently public (no Bearer required), but the collection still sends the token when present.\n- Do **not** send `ownerAuth0Id` in create-home bodies — ownership comes from the token `sub` claim.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ],
  "item": [
    {
      "name": "Health & Diagnostics",
      "description": "Public smoke checks — no Auth0 token required.",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Returns a simple JSON message confirming the Express server is up."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Backend is running', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.include('HouseIQ');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Database connection test",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db-test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db-test"]
            },
            "description": "Runs `SELECT now()` against CockroachDB Cloud via the shared pool."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns currentTime', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('currentTime');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Auth0 JWT validation. Requires a valid HouseIQ API access token in `accessToken`.",
      "item": [
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Protected. Validates the Bearer token and returns `auth0UserId` from the `sub` claim plus the full payload."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Authenticated with Auth0 subject', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.authenticated).to.eql(true);",
                  "  pm.expect(body.auth0UserId).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get current user (missing token)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Negative test — expects 401 when Authorization is omitted."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Homes",
      "description": "Create and list homes for the authenticated Auth0 user. Ownership is taken from the token `sub`, never from the request body.",
      "item": [
        {
          "name": "List my homes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/homes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes"]
            },
            "description": "Protected. Returns only homes where `owner_auth0_id` matches the token subject."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns an array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  if (body.length > 0 && body[0].id) {",
                  "    pm.environment.set('homeId', body[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create home",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Home\",\n  \"yearBuilt\": 2018,\n  \"notes\": \"Created from the HouseIQ Postman collection\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/homes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes"]
            },
            "description": "Protected. Creates a home owned by the authenticated user. `name` is required (whitespace-only names are rejected)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Returns home without owner_auth0_id', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('name');",
                  "  pm.expect(body).to.not.have.property('owner_auth0_id');",
                  "  pm.environment.set('homeId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create home (missing name)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"   \",\n  \"yearBuilt\": 2000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/homes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes"]
            },
            "description": "Negative test — trimmed empty name should return 400."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
