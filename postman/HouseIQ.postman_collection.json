            "url": {
              "raw": "{{baseUrl}}/api/homes/{{homeId}}/memory-search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes", "{{homeId}}", "memory-search"]
            },
            "description": "Embeds `query` and returns the top 5 similar memories by cosine distance. Requires OpenAI + memories with embeddings."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns results array', function () {",
                  "  const body = pm.response.json();",
