    {
      "name": "Documents",
      "description": "Upload/analyze documents, list them, create temporary download URLs, and delete. Upload expects multipart field name `document`.",
      "item": [
        {
          "name": "List documents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/homes/{{homeId}}/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes", "{{homeId}}", "documents"]
            },
            "description": "Lists document metadata for a home (no file bytes)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (Array.isArray(body) && body.length > 0 && body[0].id) {",
                  "  pm.environment.set('documentId', body[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Upload document",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "document",
                  "description": "PDF or plain-text file. Field name must be `document`.",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "documentType",
                  "value": "manual",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/homes/{{homeId}}/documents/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "homes", "{{homeId}}", "documents", "upload"]
            },
            "description": "Full document workflow: extract text → AI analysis → S3 upload → DB records. Select a PDF/TXT file for the `document` field before sending. Optional `documentType` defaults to `general`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const id = body.document?.id || body.id || body.documentId;",
                  "  if (id) {",
                  "    pm.environment.set('documentId', id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get document download URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}/download-url",
              "host": ["{{baseUrl}}"],
              "path": ["api", "documents", "{{documentId}}", "download-url"]
            },
            "description": "Creates a temporary (~5 minute) signed S3 URL for the original private file. Returns 409 if the document has no `s3Key`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or expected error', function () {",
                  "  pm.expect([200, 404, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete document",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "documents", "{{documentId}}"]
            },
            "description": "Deletes the S3 object (if present) and the CockroachDB document row."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
