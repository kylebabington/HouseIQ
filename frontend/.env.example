# Auth0 Single-Page Application settings
VITE_AUTH0_DOMAIN="your-tenant.us.auth0.com"
VITE_AUTH0_CLIENT_ID="your-auth0-spa-client-id"

# Must exactly match the Identifier of the HouseIQ API in Auth0
VITE_AUTH0_AUDIENCE="https://api.houseiq.app"

# Local Express API
VITE_API_URL="http://localhost:5000/api"